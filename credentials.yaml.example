# Talon Tools — Credentials Configuration
#
# Copy this file to credentials.yaml and fill in your values.
# Load it in your app with:  credentials.load_yaml("credentials.yaml")
#
# Nested keys are flattened to ENV_VAR style:
#   jira.url  →  JIRA_URL
#   google.keep.email  →  GOOGLE_KEEP_EMAIL
#
# Any key can also be set as an environment variable instead.
# Lookup order: YAML → custom backend → environment variable.

# ── Atlassian (Jira / Confluence) ────────────────────────────
jira:
  url: https://yourcompany.atlassian.net
  username: you@company.com
  api_token: ""

# ── Notion ───────────────────────────────────────────────────
notion:
  token: ""

# ── Google ───────────────────────────────────────────────────
google:
  credentials_file: ""          # path to OAuth client secrets JSON
  token_file: ""                # path to persisted OAuth token JSON
  keep:
    email: ""
    master_token: ""
    state_file: ""              # defaults to ~/.config/talon-google/keep_state.json

# ── Microsoft ────────────────────────────────────────────────
ms:
  client_id: ""
  tenant_id: ""
  token_file: ""                # path to MSAL token cache

# ── ServiceNow ───────────────────────────────────────────────
servicenow:
  url: https://yourcompany.service-now.com
  username: ""
  password: ""

# ── X (Twitter) ──────────────────────────────────────────────
x:
  auth_token: ""
  ct0: ""

# ── Facebook ─────────────────────────────────────────────────
facebook:
  c_user: ""
  xs: ""

# ── Spotify ──────────────────────────────────────────────────
spotify:
  client_id: ""
  client_secret: ""

# ── Jenkins ──────────────────────────────────────────────────
# Default instance (used when no server alias is specified):
jenkins:
  url: https://jenkins.company.com
  username: ""
  token: ""                     # API token (not password) — generate in Jenkins → User → Configure → API Token

# Named instances — add as many as you need (e.g. prod, staging):
# jenkins_prod:
#   url: https://jenkins-prod.company.com
#   username: ""
#   token: ""
# jenkins_staging:
#   url: https://jenkins-staging.company.com
#   username: ""
#   token: ""
